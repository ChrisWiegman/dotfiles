[user]
	name = Chris Wiegman
	email = chris.wiegman@fingerprint.com

[gpg]
    format = ssh

[commit]
    gpgsign = true

[tag]
    gpgsign = true

[pull]
    rebase = false
    ff = only

[push]
    default = simple

[color]
    ui = true

[init]
    defaultBranch = main

[merge]
    conflictstyle = zdiff3

[diff]
    colorMoved = zebra

[fetch]
    prune = true
    prunetags = true

[rebase]
    autosquash = true
    autostash = true

[core]
    autocrlf = input
    fsmonitor = true
    untrackedcache = true

[alias]
    lg = log --oneline --graph --decorate --all
    recent = branch --sort=-committerdate --format='%(refname:short) %(committerdate:relative)'
    wip = !git add -A && git commit -m "WIP"
    undo = reset --soft HEAD~1

[gpg "ssh"]
    program = "/Applications/1Password.app/Contents/MacOS/op-ssh-sign"